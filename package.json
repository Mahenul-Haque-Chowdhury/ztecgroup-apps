{
  "name": "ztecgroup-workspace",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @ztecgroup/corporate",
    "dev": "npm run dev --workspace @ztecgroup/corporate",
    "start": "npm run start --workspace @ztecgroup/corporate",
    "build:corporate": "npm run build --workspace @ztecgroup/corporate",
    "dev:corporate": "npm run dev --workspace @ztecgroup/corporate",
    "start:corporate": "npm run start --workspace @ztecgroup/corporate",
    "build:communication": "npm run build --workspace @ztecgroup/communication",
    "dev:communication": "npm run dev --workspace @ztecgroup/communication",
    "start:communication": "npm run start --workspace @ztecgroup/communication",
    "build:contentstudio": "npm run build --workspace @ztecgroup/contentstudio",
    "dev:contentstudio": "npm run dev --workspace @ztecgroup/contentstudio",
    "start:contentstudio": "npm run start --workspace @ztecgroup/contentstudio",
    "build:software": "npm run build --workspace @ztecgroup/software",
    "dev:software": "npm run dev --workspace @ztecgroup/software",
    "start:software": "npm run start --workspace @ztecgroup/software",
    "build:hospitality": "npm run build --workspace @ztecgroup/hospitality",
    "dev:hospitality": "npm run dev --workspace @ztecgroup/hospitality",
    "start:hospitality": "npm run start --workspace @ztecgroup/hospitality"
  },
  "dependencies": {
    "lightningcss": "^1.32.0",
    "lightningcss-win32-x64-msvc": "^1.32.0"
  }
}
